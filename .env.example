APP_HOST=127.0.0.1
APP_PORT=18010
UPSTREAM_BASE_URL=https://example.com/v1
UPSTREAM_API_KEY=sk-xxx
UPSTREAM_GEMINI_BASE_URL=https://example.com/v1beta
UPSTREAM_GEMINI_API_KEY=sk-xxx
UPSTREAM_TIMEOUT_SECONDS=120
GEMINI_MIN_REQUEST_INTERVAL_SECONDS=10
GEMINI_FALLBACK_MODEL=gemini-3-flash-preview
DEFAULT_UPSTREAM_MODEL=gpt-5.3-codex
DEFAULT_REASONING_EFFORT=high
OPENAI_MODEL_PREFIXES=gpt-,o1,o3,o4,text-embedding,text-moderation,whisper,tts,dall-e,omni
# JSON or legacy:target comma list, e.g.
# MODEL_MAP={"gpt-3.5-turbo-instruct":"gpt-5.3-codex"}
MODEL_MAP=

# Raw IO debug logging (for request/response forensics)
RAW_IO_LOG_ENABLED=false
RAW_IO_LOG_PATH=logs/raw_io.jsonl
RAW_IO_LOG_MAX_CHARS=120000
RAW_IO_LOG_KEEP_REQUESTS=10
